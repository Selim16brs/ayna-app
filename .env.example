# AYNA — ortam değişkenleri örneği. Gerçek .env asla repoya commit edilmez.

# Genel
NODE_ENV=development

# API
API_PORT=3000
API_GLOBAL_PREFIX=api/v1

# PostgreSQL
DATABASE_URL=postgresql://ayna:ayna@localhost:5432/ayna?schema=public

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Şifreleme (hassas alanlar — KMS ile değiştirilecek; bkz. docs/security/03)
FIELD_ENCRYPTION_KEY=change-me-32-bytes-base64

# Sağlayıcılar (abstraction — MVP'de mock; bkz. docs/planning/01 EK1-EK4)
PAYMENT_PROVIDER=mock
SMS_PROVIDER=mock
MAP_PROVIDER=mock
STORAGE_PROVIDER=mock
