// AYNA — başlangıç Prisma şeması (EPIC 1 foundation)
// Tam veri modeli: docs/planning/03-erd-draft.md
// Tarihler UTC (timestamptz). Hassas alanlar uygulama katmanında şifrelenir (docs/security/03).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  professional
  salon
  moderator
  admin
}

enum UserStatus {
  active
  suspended
  deleted
}

model User {
  id            String     @id @default(uuid()) @db.Uuid
  // Telefon uygulama katmanında şifreli saklanır (S2). Aramayı destekleyen hash ayrı tutulur.
  phoneHash     String     @unique @map("phone_hash")
  phoneEnc      Bytes      @map("phone_enc")
  role          UserRole   @default(user)
  status        UserStatus @default(active)
  defaultLocale String     @default("ru") @map("default_locale")
  timezone      String     @default("Asia/Almaty")
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("users")
}

// Kritik eylemlerin denetim kaydı — docs/security (EK H.5). safe_diff hassas veri içermez.
model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  actorId      String?  @map("actor_id") @db.Uuid
  actorRole    String?  @map("actor_role")
  action       String
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id")
  requestId    String?  @map("request_id")
  ipHash       String?  @map("ip_hash")
  deviceHash   String?  @map("device_hash")
  safeDiff     Json?    @map("safe_diff")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([resourceType, resourceId])
  @@index([actorId])
  @@map("audit_logs")
}

// Özellik bayrakları — hassas özellikler önce internal beta (EK D.4).
model FeatureFlag {
  key         String   @id
  enabled     Boolean  @default(false)
  description String?
  // Yüzde / rol bazlı kademeli açılış için opsiyonel kural seti.
  rules       Json?
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("feature_flags")
}

// --- Teklif/talep çekirdek akışı (docs/planning/09) ---

model ServiceCategory {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  nameTr    String   @map("name_tr")
  icon      String
  tone      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  quoteRequests QuoteRequest[]

  @@map("service_categories")
}

enum ProBadge {
  campaign
  verified
  today
}

enum ProviderKind {
  salon
  independent
}

model Professional {
  id              String       @id @default(uuid()) @db.Uuid
  name            String
  specialty       String
  sector          String       @default("hair")
  kind            ProviderKind @default(salon)
  district        String       @default("")
  about           String       @default("")
  rating          Decimal      @default(0) @db.Decimal(2, 1)
  reviewCount     Int          @default(0) @map("review_count")
  experienceYears Int          @default(0) @map("experience_years")
  priceFrom       Decimal      @default(0) @map("price_from") @db.Decimal(12, 2)
  friends         Int?
  imageUrl        String       @map("image_url")
  badge           ProBadge     @default(verified)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  quotes Quote[]

  @@map("professionals")
}

enum QuoteRequestStatus {
  open
  closed
}

model QuoteRequest {
  id         String             @id @default(uuid()) @db.Uuid
  userId     String?            @map("user_id") @db.Uuid
  categoryId String             @map("category_id") @db.Uuid
  note       String?
  photoUrl   String?            @map("photo_url")
  status     QuoteRequestStatus @default(open)
  createdAt  DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  category ServiceCategory @relation(fields: [categoryId], references: [id])
  quotes   Quote[]

  @@index([categoryId])
  @@map("quote_requests")
}

model Quote {
  id             String   @id @default(uuid()) @db.Uuid
  requestId      String?  @map("request_id") @db.Uuid
  professionalId String   @map("professional_id") @db.Uuid
  price          Decimal  @db.Decimal(12, 2)
  etaMin         Int      @map("eta_min")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  professional Professional  @relation(fields: [professionalId], references: [id])
  request      QuoteRequest? @relation(fields: [requestId], references: [id])

  @@index([requestId])
  @@map("quotes")
}
