// AYNA — başlangıç Prisma şeması (EPIC 1 foundation)
// Tam veri modeli: docs/planning/03-erd-draft.md
// Tarihler UTC (timestamptz). Hassas alanlar uygulama katmanında şifrelenir (docs/security/03).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  professional
  salon
  moderator
  admin
}

enum UserStatus {
  active
  suspended
  deleted
}

model User {
  id            String     @id @default(uuid()) @db.Uuid
  // Telefon uygulama katmanında şifreli saklanır (S2). Aramayı destekleyen hash ayrı tutulur.
  phoneHash     String     @unique @map("phone_hash")
  phoneEnc      Bytes      @map("phone_enc")
  // Hesap (parola tabanlı kayıt/giriş — müşteri tarafı OTP'siz)
  name          String     @default("")
  email         String?    @unique
  city          String?
  // §4.6 — women-only yaklaşımı: kayıtta cinsiyet (female | unspecified)
  gender        String     @default("unspecified")
  passwordHash  String     @default("") @map("password_hash")
  role          UserRole   @default(user)
  status        UserStatus @default(active)
  // §12.3 ceza takip — kısıtlı mod (7 gün sayaçlı); süre dolunca kalıcı engel adayı
  restrictedAt  DateTime?  @map("restricted_at") @db.Timestamptz(6)
  restrictReason String?   @map("restrict_reason")
  // §4.4 — kalıcı engel 2. katman: cihaz parmak izi (HMAC'lenmiş, platform-izinli tanımlayıcı).
  // Telefon OTP birinci katman; yüz eşleşme (biyometrik) ileri faz — burada TUTULMAZ.
  deviceHash    String?    @map("device_hash")
  // AI (§13.5): premium + ortak aylık kota sayacı
  isPremium     Boolean    @default(false) @map("is_premium")
  aiUsed        Int        @default(0) @map("ai_used")
  aiPeriod      String     @default("") @map("ai_period")
  // §11 — üyelik katmanı (free | premium | platinum) + bitiş; admin onayıyla aktifleşir.
  avatarUrl       String?   @map("avatar_url") // profil foto (data URL; medya fazında objeye taşınır)
  birthDate       DateTime? @map("birth_date") @db.Timestamptz(6) // doğum günü kutlamaları (§CRM)
  cutoutUrl       String?   @map("cutout_url") // §5.1.1 arka planı kesik portre — kredi tekrar YANMAZ
  membershipTier  String    @default("free") @map("membership_tier")
  prefsJson       String    @default("{}") @map("prefs_json") // favoriler+adresler (hesap verisi)
  membershipUntil DateTime? @map("membership_until") @db.Timestamptz(6)
  // §4.6 — telefon OTP doğrulaması (mock SMS)
  phoneVerified Boolean    @default(false) @map("phone_verified")
  // EK Z.3 — ağır KYC (uzman/salon belge doğrulaması): none | pending | approved | rejected
  kycStatus     String     @default("none") @map("kyc_status")
  kycVerifiedAt DateTime?  @map("kyc_verified_at") @db.Timestamptz(6)
  // EK Z.6 — müşteri referans programı: kişiye özel kod + davet eden (tek sefer set)
  referralCode  String?    @unique @map("referral_code")
  referredBy    String?    @map("referred_by") @db.Uuid
  defaultLocale String     @default("ru") @map("default_locale")
  timezone      String     @default("Asia/Almaty")
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("users")
}

// Kritik eylemlerin denetim kaydı — docs/security (EK H.5). safe_diff hassas veri içermez.
model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  actorId      String?  @map("actor_id") @db.Uuid
  actorRole    String?  @map("actor_role")
  action       String
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id")
  requestId    String?  @map("request_id")
  ipHash       String?  @map("ip_hash")
  deviceHash   String?  @map("device_hash")
  safeDiff     Json?    @map("safe_diff")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([resourceType, resourceId])
  @@index([actorId])
  @@map("audit_logs")
}

// Özellik bayrakları — hassas özellikler önce internal beta (EK D.4).
model FeatureFlag {
  key         String   @id
  enabled     Boolean  @default(false)
  description String?
  // Yüzde / rol bazlı kademeli açılış için opsiyonel kural seti.
  rules       Json?
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("feature_flags")
}

// --- Teklif/talep çekirdek akışı (docs/planning/09) ---

model ServiceCategory {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  nameTr    String   @map("name_tr")
  icon      String
  tone      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  quoteRequests QuoteRequest[]

  @@map("service_categories")
}

enum ProBadge {
  campaign
  verified
  today
}

enum ProviderKind {
  salon
  independent
}

model Professional {
  id              String       @id @default(uuid()) @db.Uuid
  name            String
  specialty       String
  sector          String       @default("hair")
  kind            ProviderKind @default(salon)
  city            String       @default("") // §5.1.4 — harita/arama şehir filtresi
  district        String       @default("")
  about           String       @default("")
  rating          Decimal      @default(0) @db.Decimal(2, 1)
  reviewCount     Int          @default(0) @map("review_count")
  experienceYears Int          @default(0) @map("experience_years")
  priceFrom       Decimal      @default(0) @map("price_from") @db.Decimal(12, 2)
  friends         Int?
  imageUrl        String       @map("image_url")
  portfolio       String[]     @default([]) // uzman galerisi (data URL; medya fazında objeye)
  promoJson       String       @default("[]") @map("promo_json") // §11 Platinum promosyonları (kendi profilinde görünür)
  servicesJson    String       @default("[]") @map("services_json") // §9.5 uzmanın GERÇEK hizmet/fiyat listesi
  hoursJson       String       @default("[]") @map("hours_json") // §9.5 çalışma saatleri (DayHours[])
  closedDaysJson  String       @default("[]") @map("closed_days_json") // §4.6 izin/tatil günleri (UTC ms)
  badge           ProBadge     @default(verified)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  quotes Quote[]

  @@map("professionals")
}

enum QuoteRequestStatus {
  open
  closed
}

enum LoyaltyKind {
  earn
  spend
}

// Sadakat defteri — append-only. Bakiye girişlerin toplamından türetilir (finans kuralı).
model LoyaltyEntry {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  kind      LoyaltyKind
  reason    String // i18n anahtarı (örn. 'rewards.earn.review')
  detail    String      @default("")
  points    Int // earn pozitif, spend negatif
  // §8 — kazanılan puanın son kullanma tarihi (12 ay); spend/expire kayıtlarında null
  expiresAt DateTime?   @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@map("loyalty_entries")
}

enum BookingSource {
  direct
  photo_quote
  demand
}

enum BookingStatus {
  confirmed
  pending
  completed
  cancelled
  awaiting_provider
  alternative_proposed
  no_show
  waitlist
  // §4.1-4.4 — depozito/iade yaşam döngüsü (backend'e taşındı)
  deposit_pending // uzman onayladı → kullanıcı kaporayı yükleyecek
  deposit_submitted // kullanıcı dekont yükledi → uzman onayı bekleniyor
  refund_pending // serbest iptal → uzman iade edecek
  refund_submitted // uzman iade dekontu yükledi → kullanıcı onayı bekleniyor
  disputed // taraflar itiraz açtı (admin kuyruğu)
  reassigned_pending // uzman ayrıldı → yeni uzman atandı, kullanıcı onayı bekleniyor
}

// Randevu kaydı. id istemci tarafından üretilir (mobil store ile tutarlı).
// Onay/alternatif pazarlık döngüsü (Build Brief §1.6).
model Booking {
  id                 String        @id
  // §5.6/çift-yönlü puanlama önkoşulu: randevuyu sahibine bağlar (offline'da null)
  userId             String?       @map("user_id") @db.Uuid
  source             BookingSource
  service            String
  proId              String?       @map("pro_id")
  proName            String        @map("pro_name")
  proImage           String        @map("pro_image")
  uzmanName          String?       @map("uzman_name")
  // §2.2/§5 — offline (salon kaydı) randevuda müşteri adı
  customerName       String?       @map("customer_name")
  // §6.C/Faz3 — randevu türü (normal | group | express) + grup kişi sayısı
  bookingKind        String        @default("normal") @map("booking_kind")
  groupSize          Int?          @map("group_size")
  dateLabel          String        @map("date_label")
  proposedDateLabel  String?       @map("proposed_date_label")
  inDays             Int           @map("in_days")
  // §4.2 — kesin zaman (atomik slot lock için); mobil startMs/durationMin'den
  startAt            DateTime?     @map("start_at") @db.Timestamptz(6)
  durationMin        Int?          @map("duration_min")
  // §4.1 — uzmanın önerdiği alternatif başlangıç (mobil proposedStartMs ile hizalı)
  proposedStartAt    DateTime?     @map("proposed_start_at") @db.Timestamptz(6)
  price              Decimal       @db.Decimal(12, 2)
  status             BookingStatus @default(confirmed)
  // §6.C — iptal sebebi (kullanıcı "neden gelemiyorum" iletebilir)
  cancelReason       String?       @map("cancel_reason")
  // §4.1-4.4 — depozito/iade alanları
  depositAmount      Int?          @map("deposit_amount") // KZT kapora tutarı
  depositReceiptUri  String?       @map("deposit_receipt_uri") // kullanıcının kapora dekontu
  refundReceiptUri   String?       @map("refund_receipt_uri") // uzmanın iade dekontu
  depositDeadline    DateTime?     @map("deposit_deadline") @db.Timestamptz(6) // dekont son yükleme
  depositForfeited   Boolean       @default(false) @map("deposit_forfeited") // geç iptal/no-show: kapora yandı
  providerNoShow     Boolean       @default(false) @map("provider_no_show") // uzman gelmedi
  reviewed           Boolean       @default(false)
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([status])
  @@map("bookings")
}

model QuoteRequest {
  id         String             @id @default(uuid()) @db.Uuid
  userId     String?            @map("user_id") @db.Uuid
  categoryId String             @map("category_id") @db.Uuid
  note       String?
  photoUrl   String?            @map("photo_url")
  status     QuoteRequestStatus @default(open)
  createdAt  DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  // §5.2 Faz A — reverse marketplace gerçek akış alanları
  mode       String    @default("photo") // photo | describe
  city       String    @default("") // §9.3 — teklif hakkı aynı şehirdeki uzmanlarda
  budget     Decimal?  @db.Decimal(12, 2)
  collectMin Int       @default(180) @map("collect_min")
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz(6)
  serviceId       String? @map("service_id") // taksonomi alt hizmet (opsiyonel)
  bookingId       String? @map("booking_id") // seçim sonrası oluşan randevu
  selectedQuoteId String? @map("selected_quote_id") // kazanan teklif
  preferredSlotsJson String @default("[]") @map("preferred_slots_json") // kullanıcının İSTEDİĞİ saatler (UTC ms)

  category ServiceCategory @relation(fields: [categoryId], references: [id])
  quotes   Quote[]

  @@index([categoryId])
  @@index([city, status])
  @@map("quote_requests")
}

model Quote {
  id             String   @id @default(uuid()) @db.Uuid
  requestId      String?  @map("request_id") @db.Uuid
  // Keşif kataloğu bağı (bağımsız uzmanlarda dolu; profil/puan gösterimi için)
  professionalId String?  @map("professional_id") @db.Uuid
  // §5.2 Faz A — teklifi veren uzmanın HESABI (bildirim + mükerrer teklif önleme)
  userId         String?  @map("user_id") @db.Uuid
  price          Decimal  @db.Decimal(12, 2)
  etaMin         Int      @map("eta_min")
  note           String?
  // Uzmanın önerdiği müsait başlangıçlar (UTC ms listesi, JSON)
  slotsJson      String   @default("[]") @map("slots_json")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  professional Professional? @relation(fields: [professionalId], references: [id])
  request      QuoteRequest? @relation(fields: [requestId], references: [id])

  @@unique([requestId, userId]) // uzman başına 1 teklif
  @@index([requestId])
  @@map("quotes")
}

// --- İşletme & uzman kaydı (Build Brief §3) ---

enum BusinessStatus {
  pending
  approved
  rejected
}

model Business {
  id           String         @id @default(uuid()) @db.Uuid
  ownerUserId  String         @map("owner_user_id") @db.Uuid
  name         String
  ownerName    String         @default("") @map("owner_name")
  sector       String         @default("")
  about        String         @default("")
  city         String         @default("")
  district     String         @default("")
  address      String         @default("")
  phone        String         @default("")
  email        String         @default("")
  workingHours String         @default("") @map("working_hours")
  taxId        String         @default("") @map("tax_id")
  categories   String[]       @default([])
  photos       String[]       @default([])
  docUrl       String?        @map("doc_url")
  // Keşif listesine (professionals) köprü — salon panelinde randevu/yorum kapsamı için
  professionalId String?      @map("professional_id")
  status       BusinessStatus @default(pending)
  rejectReason String?        @map("reject_reason")
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([status])
  @@index([ownerUserId])
  @@map("businesses")
}

enum SpecialistKind {
  salon_bound
  independent
}

model Specialist {
  id           String         @id @default(uuid()) @db.Uuid
  userId       String         @unique @map("user_id") @db.Uuid
  businessId   String?        @map("business_id") @db.Uuid
  // §7 — uzmanın keşif kataloğundaki karşılığı (Professional.id); yorumlar subjectId = bu id.
  proId        String?        @map("pro_id")
  kind         SpecialistKind @default(independent)
  bio          String         @default("")
  certificates String[]       @default([])
  featured     Boolean        @default(false)
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([businessId])
  @@map("specialists")
}

enum InviteCodeStatus {
  active
  used
  revoked
}

// İşletme doğrulama kodu — uzmanın işletmeye bağlandığını ispatlar (§3.3)
model BusinessInviteCode {
  id           String           @id @default(uuid()) @db.Uuid
  businessId   String           @map("business_id") @db.Uuid
  code         String           @unique
  status       InviteCodeStatus @default(active)
  usedByUserId String?          @map("used_by_user_id") @db.Uuid
  attempts     Int              @default(0)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([businessId])
  @@map("business_invite_codes")
}

// --- Uzman takvimi: müsaitlik + bloklar (Build Brief §1.5 / §2.2 / §3.6) ---

// Haftalık müsaitlik (online randevu boşlukları). 1:1 uzman.
model SpecialistAvailability {
  specialistId String   @id @map("specialist_id") @db.Uuid
  // {"1":{"start":"10:00","end":"18:00"}} — anahtar JS getDay() (0=Paz..6=Cmt)
  weeklyHours  Json     @map("weekly_hours")
  slotMinutes  Int      @default(60) @map("slot_minutes")
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("specialist_availability")
}

enum BlockKind {
  offline
  booking
}

// Dolu zaman blokları — offline randevular + onaylı online randevular (çakışma önleme).
model SpecialistBlock {
  id           String    @id @default(uuid()) @db.Uuid
  specialistId String    @map("specialist_id") @db.Uuid
  startAt      DateTime  @map("start_at") @db.Timestamptz(6)
  endAt        DateTime  @map("end_at") @db.Timestamptz(6)
  kind         BlockKind @default(offline)
  label        String    @default("")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([specialistId, startAt])
  @@map("specialist_blocks")
}

// Ortalama piyasa fiyatı (kategori × şehir) — %40 alt sınır kuralı (Build Brief §1.3).
// Dinamik gerçek tekliflerden hesaplanır; yeterli örnek yoksa admin tohumlu temel fiyat.
model MarketPrice {
  id        String   @id @default(uuid()) @db.Uuid
  category  String
  city      String   @default("")
  basePrice Decimal  @map("base_price") @db.Decimal(12, 2)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([category, city])
  @@map("market_prices")
}

// --- Çift-kör + eşikli puanlama (Build Brief §1.8) ---
// Puanlar iki taraf da verene kadar gizli; agregat eşik aşılınca görünür.
model Rating {
  id         String    @id @default(uuid()) @db.Uuid
  bookingId  String    @map("booking_id")
  raterRole  String    @map("rater_role") // 'user' | 'specialist'
  subjectId  String    @map("subject_id") // değerlendirilen (uzman/işletme veya kullanıcı)
  score      Int
  comment    String    @default("")
  serviceTag String    @default("") @map("service_tag") // §6.D opsiyonel hizmet etiketi
  // EK Z.10 — öncesi/sonrası foto galerisi (string[] URI). Mahremiyet: yorum sahibinin
  // kimliği yine gizli (authorLabel); foto app içinde indirilemez (istemci kuralı).
  photos     Json?
  // Gizlilik: salon/uzman yorum sahibinin KİMLİĞİNİ göremez — yalnızca bu etiket
  // ("Doğrulanmış üye" ya da kullanıcının seçtiği ad). Rating'de userId tutulmaz.
  authorLabel String   @default("Doğrulanmış üye") @map("author_label")
  visible    Boolean   @default(false)
  // §6.D — açılınca kalıcı (silme yolu YOK); uzman/işletme yanıt verebilir (silemez)
  reply      String    @default("")
  repliedAt  DateTime? @map("replied_at") @db.Timestamptz(6)
  // §7.2 — negatif yorum itirazı: admin kuyruğuna düşer; yorum SÜREÇ BOYUNCA görünür kalır (otomatik gizleme YOK)
  disputed      Boolean   @default(false)
  disputeReason String?   @map("dispute_reason")
  disputedAt    DateTime? @map("disputed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([subjectId, visible])
  @@index([bookingId])
  @@index([disputed])
  @@map("ratings")
}

// §4.6 — Telefon OTP doğrulama kodu. Kod düz metin saklanmaz (HMAC).
// Mock SMS; tek seferlik, süreli, deneme limitli.
model OtpCode {
  id         String    @id @default(uuid()) @db.Uuid
  phoneHash  String    @map("phone_hash")
  codeHash   String    @map("code_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  attempts   Int       @default(0)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([phoneHash])
  @@map("otp_codes")
}

// §12 — Kampanya / promosyon. İşletme veya platform geneli; keşif vitrininde görünür.
model Campaign {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  subtitle  String   @default("")
  badge     String   @default("") // örn "%20", "2+1"
  category  String? // hedef kategori kodu (varsa o kategoriye köprü)
  image     String
  i18n      Json? // §14.5 — 3 dil: kk/ru title/subtitle override'ları
  tone      String   @default("rose")
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([active, sortOrder])
  @@map("campaigns")
}

// Komisyon tahsilat defteri (append-only ledger) — salondan tahsil edilen platform komisyonu.
// Alacak = (tamamlanan online randevulardan kazanılan komisyon) − (bu defterdeki tahsilat toplamı).
model CommissionPayout {
  id        String   @id @default(uuid()) @db.Uuid
  proId     String   @map("pro_id") // salon/uzman anahtarı (keşif listesi id'si)
  proName   String   @map("pro_name") // görüntü için anlık kopya
  amount    Decimal  @db.Decimal(12, 2) // tahsil edilen tutar (KZT, pozitif)
  note      String   @default("")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([proId])
  @@map("commission_payouts")
}

// Reklam banner'ı — keşif ekranındaki sponsorlu şerit (belirli bir uzmana/salona bağlı)
model AdBanner {
  id        String   @id @default(uuid()) @db.Uuid
  proId     String   @map("pro_id") // hedef uzman/salon (keşif listesi id'si)
  title     String
  subtitle  String   @default("")
  image     String
  i18n      Json? // §14.5 — 3 dil: kk/ru title/subtitle override'ları
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([active, sortOrder])
  @@map("ad_banners")
}

// Admin ayarlanabilir parametreler (örn. puan görünürlük eşiği).
// §12.9 — sayısal oranlar intValue'da; API anahtarı / şehir listesi gibi metinler strValue'da.
model Setting {
  key      String  @id
  intValue Int     @default(0) @map("int_value")
  strValue String? @map("str_value")

  @@map("settings")
}

// ── §12.6 İçerik Yönetimi — AYNA Blog ────────────────────────────────────
// Admin yazar/yayınlar; yazıya kategori bağlanır → app'te otomatik "Teklif al" CTA'sı.
model BlogArticle {
  id            String    @id @default(uuid()) @db.Uuid
  title         String
  tag           String // görünen etiket ("Sağlık", "Bakım"…)
  categoryCode  String?   @map("category_code") // ServiceCategory.code → app CTA
  readMin       Int       @default(3) @map("read_min")
  image         String    @default("")
  excerpt       String
  body          String[] // paragraf dizisi
  i18n          Json? // §14.5 — 3 dil: kk/ru title/tag/excerpt/body override'ları
  published     Boolean   @default(false)
  publishedAt   DateTime? @map("published_at") @db.Timestamptz(6)
  applicationId String?   @unique @map("application_id") @db.Uuid // hangi başvurudan geldi
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([published])
  @@map("blog_articles")
}

// Kullanıcı blog başvurusu — admin onaylar → puan otomatik verilir (loyalty ledger).
model BlogApplication {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String?   @map("user_id") @db.Uuid
  authorName String    @map("author_name")
  title      String
  excerpt    String    @default("")
  body       String[]
  tag        String    @default("")
  status     String    @default("pending") // pending | approved | rejected
  points     Int       @default(0) // onayda verilen puan
  note       String    @default("") // red gerekçesi
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  reviewedAt DateTime? @map("reviewed_at") @db.Timestamptz(6)

  @@index([status])
  @@map("blog_applications")
}

// Haftalık W2W (Women to Women) teması — app'te haftanın sorusu/teması.
model WeeklyTheme {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  prompt    String
  i18n      Json? // §14.5 — 3 dil: kk/ru title/prompt override'ları
  weekStart DateTime @map("week_start") @db.Timestamptz(6)
  active    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("weekly_themes")
}

// §5.5 W2W (Women to Women) — kadın topluluğu paylaşımları + moderasyon.
// status: published | pending (moderasyon kuyruğu) | hidden (gizlendi/engellendi)
model CirclePost {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String?  @map("user_id") @db.Uuid
  category         String
  text             String
  anonymous        Boolean  @default(false)
  authorLabel      String   @default("AYNA Üyesi") @map("author_label")
  helpful          Int      @default(0)
  reports          Int      @default(0)
  status           String   @default("published")
  moderationReason String   @default("") @map("moderation_reason")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([status])
  @@map("circle_posts")
}

// §5.5 — W2W takip grafiği: kullanıcı-kimliğiyle (isim değil)
model CircleFollow {
  id         String   @id @default(uuid()) @db.Uuid
  followerId String   @map("follower_id") @db.Uuid
  targetId   String   @map("target_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([followerId, targetId])
  @@index([targetId])
  @@map("circle_follows")
}

model CircleComment {
  id          String   @id @default(uuid()) @db.Uuid
  postId      String   @map("post_id") @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  authorLabel String   @default("AYNA Üyesi") @map("author_label")
  text        String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([postId])
  @@map("circle_comments")
}

model CircleReport {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  reason    String   @default("")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([postId])
  @@map("circle_reports")
}

// §12.4/§12.3 Depozito/iade anlaşmazlık kuyruğu — dekont görselleri admin panelde incelenir.
// kind: deposit (depozito itirazı) | refund (iade dekontu onayı) · status: open | approved | rejected
model Dispute {
  id         String    @id @default(uuid()) @db.Uuid
  bookingRef String    @map("booking_ref") // mobil randevu id'si
  userId     String?   @map("user_id") @db.Uuid
  proName    String    @map("pro_name")
  service    String    @default("")
  kind       String    @default("deposit")
  amount     Decimal   @default(0) @db.Decimal(12, 2)
  receiptUri String?   @map("receipt_uri") // incelenecek dekont görseli
  note       String    @default("") // açan tarafın açıklaması
  status     String    @default("open")
  resolution String    @default("") // admin karar notu
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt DateTime? @map("resolved_at") @db.Timestamptz(6)

  @@index([status])
  @@map("disputes")
}

// §12.8 Komisyon dönem faturası — aylık tahakkuk→tahsilat döngüsü.
// status: pending (bekliyor) | collected (ödendi) | overdue (gecikti)
model CommissionInvoice {
  id               String    @id @default(uuid()) @db.Uuid
  proId            String    @map("pro_id") // keşif listesi id'si (booking.proId)
  proName          String    @map("pro_name")
  ownerUserId      String?   @map("owner_user_id") @db.Uuid // salon sahibi hesabı (bildirim + kısıt)
  periodStart      DateTime  @map("period_start") @db.Timestamptz(6)
  periodEnd        DateTime  @map("period_end") @db.Timestamptz(6)
  bookingsCount    Int       @default(0) @map("bookings_count")
  grossRevenue     Decimal   @default(0) @map("gross_revenue") @db.Decimal(12, 2)
  commissionAmount Decimal   @default(0) @map("commission_amount") @db.Decimal(12, 2)
  dueDate          DateTime  @map("due_date") @db.Timestamptz(6)
  status           String    @default("pending")
  receiptUri       String?   @map("receipt_uri") // pro'nun yüklediği ödeme dekontu
  receiptAt        DateTime? @map("receipt_at") @db.Timestamptz(6)
  collectedAt      DateTime? @map("collected_at") @db.Timestamptz(6)
  restrictedApplied Boolean  @default(false) @map("restricted_applied") // gecikme kısıtı uygulandı mı
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([proId])
  @@index([status])
  @@index([ownerUserId])
  @@map("commission_invoices")
}

// §11 — ÜYELİK ABONELİĞİ: uzman/salon Premium/Platinum satın alır (app-dışı ödeme + dekont),
// admin dekontu doğrulayıp aktive eder. status: pending | active | rejected | expired.
model Subscription {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  userName    String    @map("user_name")
  tier        String // premium | platinum
  amount      Decimal   @default(0) @db.Decimal(12, 2)
  status      String    @default("pending")
  receiptUri  String?   @map("receipt_uri") // app-dışı ödeme dekontu (Kaspi/banka)
  receiptAt   DateTime? @map("receipt_at") @db.Timestamptz(6)
  periodStart DateTime? @map("period_start") @db.Timestamptz(6)
  periodEnd   DateTime? @map("period_end") @db.Timestamptz(6)
  reviewedAt  DateTime? @map("reviewed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

// §profil-onay — SALON/UZMAN profil değişikliği admin onayı olmadan uygulanmaz.
// changes: önerilen alanların JSON'u. status: pending | approved | rejected.
model ProfileChangeRequest {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  userName   String    @map("user_name")
  role       String // professional | salon
  changes    Json // önerilen değişiklikler (name, social, hours, certs, about, address...)
  status     String    @default("pending")
  reviewedAt DateTime? @map("reviewed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([status])
  @@map("profile_change_requests")
}

// §12.10 Bildirim Merkezi — segment bazlı toplu duyuru + gönderim geçmişi.
// segment: all | premium | professionals | salons | city
model Announcement {
  id             String   @id @default(uuid()) @db.Uuid
  title          String
  body           String
  // §14.5 — 3 dil: base alanlar tr (kaynak); i18n = { kk: {...}, ru: {...} } üzerine yazar
  i18n           Json?
  segment        String   @default("all")
  city           String?  // segment=city ise hedef şehir
  recipientCount Int      @default(0) @map("recipient_count")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt])
  @@map("announcements")
}

// EK Z.1 — Uygulama-içi DM mesajlaşma. 1:1 sohbet: müşteri ↔ uzman/salon.
// Çift (customerId, proUserId) benzersiz → çift başına tek konuşma.
model Conversation {
  id            String    @id @default(uuid()) @db.Uuid
  customerId    String    @map("customer_id") @db.Uuid
  proUserId     String    @map("pro_user_id") @db.Uuid
  // Bağlam (izlenebilirlik) — hangi randevu/talep üzerinden başladı
  bookingId     String?   @map("booking_id")
  requestId     String?   @map("request_id") @db.Uuid
  lastMessageAt DateTime? @map("last_message_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  messages Message[]

  @@unique([customerId, proUserId])
  @@index([customerId])
  @@index([proUserId])
  @@map("conversations")
}

// moderation: ok | flagged (yasaklı ifade — alıcıya gösterilmez, admin kuyruğu)
model Message {
  id             String    @id @default(uuid()) @db.Uuid
  conversationId String    @map("conversation_id") @db.Uuid
  senderId       String    @map("sender_id") @db.Uuid
  body           String
  moderation     String    @default("ok")
  readAt         DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

// EK Z.8 — In-app Kaspi ödeme (simülasyon adaptörü; merchant gelince gerçek adaptöre geçilir).
// §8.2 — puan bir ödemenin en fazla %50'sini karşılar; kalan nakit Kaspi ile.
// status: pending | paid | failed | refunded. amount=hizmet bedeli, cashAmount=Kaspi ile ödenen.
model Payment {
  id          String    @id @default(uuid()) @db.Uuid
  bookingId   String    @map("booking_id")
  userId      String    @map("user_id") @db.Uuid
  amount      Decimal   @db.Decimal(12, 2)
  pointsUsed  Int       @default(0) @map("points_used")
  cashAmount  Decimal   @map("cash_amount") @db.Decimal(12, 2)
  method      String    @default("kaspi")
  status      String    @default("pending")
  providerRef String?   @map("provider_ref")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  paidAt      DateTime? @map("paid_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([bookingId])
  @@map("payments")
}

// EK Z.5 — Uzaktan push: cihaz Expo push token kaydı. token benzersiz (cihaz başına tek).
model PushToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  platform  String   @default("")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@map("push_tokens")
}

// EK Z.3 — Ağır KYC: uzman/salon belge doğrulaması (OTP+yüz tespiti self-publish'e EK).
// documents: string[] belge görsel URI'leri. status: pending | approved | rejected.
model KycVerification {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  docType     String    @map("doc_type")
  documents   Json
  status      String    @default("pending")
  note        String    @default("")
  submittedAt DateTime  @default(now()) @map("submitted_at") @db.Timestamptz(6)
  reviewedAt  DateTime? @map("reviewed_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([status])
  @@map("kyc_verifications")
}

// EK Z.2 — Randevu güvenlik katmanı. Güvenilen kişi (acil durum kişisi).
// phone: PII — ASLA log/analytics'e yazılmaz (CLAUDE.md privacy-by-design).
model TrustedContact {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String
  phone     String
  relation  String   @default("")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@map("trusted_contacts")
}

// Güvenli mod oturumu — konum paylaşımı VARSAYILAN KAPALI; oturum açmak açık rızadır.
// status: active | sos | ended. Ham konum (lastLat/lastLng) log/audit'e yazılmaz.
model SafetySession {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  bookingId      String?   @map("booking_id")
  status         String    @default("active")
  lastLat        Float?    @map("last_lat")
  lastLng        Float?    @map("last_lng")
  lastLocationAt DateTime? @map("last_location_at") @db.Timestamptz(6)
  sosAt          DateTime? @map("sos_at") @db.Timestamptz(6)
  startedAt      DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  endedAt        DateTime? @map("ended_at") @db.Timestamptz(6)

  @@index([userId])
  @@map("safety_sessions")
}

// Kullanıcı-kullanıcı engelleme (spec satır 242/257) — engellinin içeriği/mesajı görünmez.
model UserBlock {
  id        String   @id @default(uuid()) @db.Uuid
  blockerId String   @map("blocker_id") @db.Uuid
  blockedId String   @map("blocked_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("user_blocks")
}
